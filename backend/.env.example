# Copy this to .env — NEVER commit .env to git

# Port the server runs on
PORT=4000

# Your Resend API key — get it from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address you want contact form submissions sent TO
# This should be the email you verified with Resend
TO_EMAIL=anitamavani90@gmail.com

# The "from" address shown in the email
# Must use a domain you've verified in Resend
# For testing you can use: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# Comma-separated list of allowed frontend origins
# Local dev + your Netlify URL once deployed
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio.netlify.app
